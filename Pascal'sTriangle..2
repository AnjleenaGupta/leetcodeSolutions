class Solution {
public:
    vector<int> solve(int row){
         vector<int> res;
         long long ans=1;
        if(row==0){
             res.push_back(ans) ;
             return res;
        }
       
        res.push_back(1);
        for(int i=1;i<row;i++){
            ans= ans*(row+1-i);
            ans=ans/i;
            res.push_back(ans);
        }
        res.push_back(1);
        return res;
    }
    vector<int> getRow(int rowIndex) {
      return solve(rowIndex);  
    }
};